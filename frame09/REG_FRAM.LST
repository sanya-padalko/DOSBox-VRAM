    468				     ; BoundedHorLine(lbound, rbound, symb, len, ind)
    469				     ;
    470				     ; Entry:[stack] lbound  = symbol for line's start
    471				     ;	     [stack] rbound  = symbol for line's end
    472				     ;	     [stack] symb    = symbol of line's	middle
    473				     ;	     [stack] len     = len of line's middle
    474				     ;	     [stack] ind     = index from which	line will be printing (es:[ind])
    475				     ;
    476				     ; Result:	     DI	     = ind
    477				     ;		     AX	     = returing	address
